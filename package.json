{
  "name": "@guoyunhe/oxlint-config",
  "version": "1.0.0",
  "description": "A shared configuration for oxlint by Guo Yunhe.",
  "keywords": [
    "code-style",
    "eslint",
    "lint",
    "linting",
    "oxlint",
    "oxlint-config",
    "shared-config",
    "typescript"
  ],
  "homepage": "https://github.com/guoyunhe/oxlint-config#readme",
  "bugs": {
    "url": "https://github.com/guoyunhe/oxlint-config/issues"
  },
  "license": "MPL-2.0",
  "author": {
    "name": "Guo Yunhe",
    "email": "i@guoyunhe.me",
    "url": "https://guoyunhe.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guoyunhe/oxlint-config.git"
  },
  "funding": "https://github.com/sponsors/guoyunhe",
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rive build",
    "build:watch": "rive build --watch",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt .",
    "prepare": "husky",
    "start": "rive start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@mdx-js/react": "^3.1.1",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rive": "^3.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,mjs,mts,ts,tsx,vue}": "oxlint --fix",
    "*.{cjs,css,cts,html,js,json,jsx,less,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}": "oxfmt"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "rive": {
    "template": "node",
    "doc": {
      "basename": "/oxlint-config/"
    }
  }
}
